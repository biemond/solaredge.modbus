{
  "name": {
    "en": "Huawei LUNA2000 Battery",
    "de": "Huawei LUNA2000 Batterie"
  },
  "class": "battery",
  "energy": {
    "homeBattery": true
  },
  "capabilities": [
    "measure_power",
    "battery",
    "measure_battery"
  ],
  "capabilitiesOptions": {
    "measure_power": {
      "decimals": 0,
      "title": {
        "en": "Battery Power",
        "de": "Batterieleistung"
      }
    }
  },
  "platforms": ["local"],
  "connectivity": ["lan"],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png"
  },
  "pair": [
    {
      "id": "start"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Inverter settings",
        "de": "Wechselrichtereinstellungen"
      },
      "children": [
        {
          "id": "address",
          "type": "text",
          "value": "0.0.0.0",
          "label": {
            "en": "IP Address",
            "de": "IP-Adresse"
          }
        },
        {
          "id": "port",
          "type": "number",
          "value": 1502,
          "step": 1,
          "label": {
            "en": "Port",
            "de": "Port"
          }
        },
        {
          "id": "id",
          "type": "number",
          "value": 1,
          "step": 1,
          "attr": {
            "min": 0,
            "max": 50
          },
          "label": {
            "en": "Inverter ID",
            "nl": "Inverter ID",
            "de": "Wechselrichter-ID"
          }
        }
      ]
    }
  ]
}
